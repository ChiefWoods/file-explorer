{
  "name": "file-explorer",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun .output/server/index.mjs",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "docker:build": "docker build --no-cache --progress=plain -t file-explorer:local .",
    "docker:db:up": "docker compose up -d db",
    "docker:db:start": "docker compose start db",
    "docker:db:stop": "docker compose stop db",
    "docker:db:down": "docker compose down",
    "docker:test-db:up": "docker compose --profile test up -d test-db",
    "docker:test-db:start": "docker compose start test-db",
    "docker:test-db:stop": "docker compose stop test-db",
    "docker:test-db:down": "docker compose --profile test down",
    "docker:test-db:reset": "docker compose --profile test down -v",
    "db:migrate": "bunx --bun prisma migrate dev --name init",
    "db:generate": "bunx --bun prisma generate",
    "db:studio": "bunx --bun prisma studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/figtree": "^5.2.10",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-form-start": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.260311-beta",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "prisma": "^7.5.0",
    "react-grab": "^0.1.32",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
